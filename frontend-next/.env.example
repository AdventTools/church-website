# ─────────────────────────────────────────────────────────────────────────────
#  Next.js frontend — environment
#  Copy to `.env.local` and fill in. NEVER commit `.env.local` (it is gitignored).
#  NEXT_PUBLIC_* values are inlined into the browser bundle (not secret).
# ─────────────────────────────────────────────────────────────────────────────

# Strapi API base URL (server-side data fetching + /uploads proxy).
STRAPI_URL=http://127.0.0.1:1337

# Canonical public site URL (your own domain) — drives canonical/hreflang,
# sitemap.xml, robots.txt and Open Graph URLs. REQUIRED in production.
NEXT_PUBLIC_SITE_URL=https://www.example.org

# Google Analytics 4 measurement ID (G-XXXXXXX). Empty = analytics + consent
# banner disabled.
NEXT_PUBLIC_GA_ID=

# YouTube channel ID (UC…) — powers sermons (public RSS) + live detection.
# Empty = sermons & live features hidden.
YT_CHANNEL_ID=
# YouTube Data API v3 key — needed ONLY for automatic live-broadcast detection.
# Empty = no auto live detection (sermons via RSS still work).
YT_API_KEY=

# Shared secret for the contact-form proxy to Strapi — MUST equal the CMS's
# MAIL_PROXY_TOKEN. Empty = contact form returns 503.
MAIL_PROXY_TOKEN=change-me-long-random
