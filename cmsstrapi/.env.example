# ─────────────────────────────────────────────────────────────────────────────
#  Strapi CMS — environment
#  Copy to `.env` and fill in. NEVER commit the real `.env` (it is gitignored).
#  Generate the secrets below with:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=1337
# Public URL of the CMS (behind a reverse proxy). Leave empty to deduce from request.
PUBLIC_URL=https://cms.example.org

# Security secrets — REQUIRED (Strapi will not start without them)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
JWT_SECRET=change-me

# Database — MySQL / MariaDB (config/database.js uses the mysql2 client)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=church_cms
DATABASE_USERNAME=church
DATABASE_PASSWORD=change-me
DATABASE_SSL=false

# Contact form
# Shared secret between the Next.js server and Strapi — must equal the frontend's
# MAIL_PROXY_TOKEN. Only the Next server sends it; it never reaches the browser.
MAIL_PROXY_TOKEN=change-me-long-random
# SMTP account password — kept ONLY here (server-side), never in the CMS/DB/API.
# The rest of the SMTP settings (host, port, from, recipient) are edited in the
# Strapi admin, single-type "E-mail (SMTP)".
SMTP_PASSWORD=your-smtp-password
